# SmartLogi – Environment Variables
# Copy this file to .env and fill in real values.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SmartLogi
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── API Prefix ────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/smartlogi

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-super-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (* allows all – fine for hackathon)
ALLOWED_ORIGINS=*

# ── AI / ML Settings ──────────────────────────────────────────────────────────
# Delay model thresholds (adjust scoring without code changes)
DELAY_SCORE_MEDIUM_THRESHOLD=4
DELAY_SCORE_HIGH_THRESHOLD=7

# Route improvement cap (%) returned by route_optimizer
ROUTE_IMPROVEMENT_CAP_PCT=40

# ── Sustainability ─────────────────────────────────────────────────────────────
# kg CO₂ absorbed per tree per year (used to calculate tree offsets)
TREE_CO2_ABSORPTION_KG=21

# ── External APIs (optional – leave blank for hackathon mock mode) ─────────────
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
